# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/smartinvoice?schema=public"

# Security: Secret key for generating JWT tokens (Authentication)
JWT_SECRET="your_very_secure_jwt_secret_here"

# Security: 32-character key for AES-256 encryption (Protects API keys and Tokens in the Database)
# Must be exactly 32 characters long
ENCRYPTION_KEY="12345678901234567890123456789012"

# Application Environment (development/production)
APP_ENV="development"

# Port where the Backend server will run
PORT=5000

# System Identity URLs (Used for redirections and image links)
FRONTEND_URL="http://localhost:5173"
APP_URL="http://localhost:5000"

# --- Meta Configurations (WhatsApp Business Cloud API) ---

# App ID from developers.facebook.com
META_APP_ID="your_meta_app_id"

# Meta App Secret Key
META_APP_SECRET="your_meta_app_secret"

# Callback URL configured in the Meta panel for completing OAuth login
# Example: https://your-domain.ngrok-free.dev/api/whatsapp/auth/callback
META_REDIRECT_URI="http://localhost:5000/api/whatsapp/auth/callback"

# OAuth Scopes for WhatsApp Business API
META_SCOPES="whatsapp_business_messaging,whatsapp_business_management"

# Webhook: Verification token to be configured in the Meta Developer Panel
WHATSAPP_VERIFY_TOKEN="your_custom_verify_token_here"
